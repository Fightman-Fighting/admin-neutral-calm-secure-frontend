# Copy to .env.local for local dev (Next.js loads .env.local automatically).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin API (Express backend). Defaults to http://localhost:4001 if omitted.
NEXT_PUBLIC_API_URL=http://localhost:4001

# Where to send users for “main app” login (AuthContext). Defaults to http://localhost:3000/login.
# NEXT_PUBLIC_APP_LOGIN_URL=http://localhost:3000/login

# Server-only: used by src/app/api/profile-role/route.ts to read profiles.role (never expose in client code).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

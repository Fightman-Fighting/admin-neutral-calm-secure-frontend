# Same Supabase project as neutral-calm-secure
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used by /api/profile-role to read profiles.role (never commit real keys)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin API (admin-neutral-calm-secure-backend), default port 4001 — prompt routes live here
NEXT_PUBLIC_API_URL=http://localhost:4001

# Where to send non-admin users (main app login)
NEXT_PUBLIC_APP_LOGIN_URL=http://localhost:3000/login
